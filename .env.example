# Quran Foundation Content API credentials
VITE_QURAN_CLIENT_ID=""
VITE_QURAN_AUTH_TOKEN=""

# Quran Foundation OAuth base URL
# Pre-live (testing): https://prelive-oauth2.quran.foundation
# Production:         https://oauth2.quran.foundation  (default if unset)
VITE_QF_AUTH_BASE="https://prelive-oauth2.quran.foundation"

# Gemini AI (reflection questions)
VITE_GEMINI_API_KEY=""

# --- Vercel / server-side environment variables (set in Vercel dashboard, NOT here) ---
# QF_CLIENT_ID=       (same value as VITE_QURAN_CLIENT_ID)
# QF_CLIENT_SECRET=   (from QF developer dashboard)
# QF_AUTH_BASE=       (same value as VITE_QF_AUTH_BASE)
